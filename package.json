{
  "name": "img-oriz-in",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Free online image tools — 100% client-side, zero uploads, privacy-first",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "astro": "^6.1.1",
    "@astrojs/react": "^5.0.2",
    "@astrojs/cloudflare": "^13.1.4",
    "@astrojs/partytown": "^2.1.6",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "lucide-react": "^1.7.0",
    "browser-image-compression": "^2.0.2",
    "jszip": "^3.10.1",
    "fabric": "^7.2.0",
    "react-image-crop": "^11.0.10",
    "gif.js": "^0.2.0",
    "heic2any": "^0.0.4",
    "@imgly/background-removal": "^1.7.0",
    "face-api.js": "^0.22.2",
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@playwright/test": "^1.58.2",
    "wrangler": "^4.77.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "jsdom": "^27.4.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
