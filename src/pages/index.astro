---
import Base from "../layouts/Base.astro";
import { tools, categoryLabels } from "../lib/toolMeta";
import { Minimize2, Maximize2, Crop, ArrowRightLeft, ImageIcon, Paintbrush, Sparkles, Eraser, Droplets, Laugh, RotateCw, Code, ScanFace } from "lucide-react";

const iconMap: Record<string, any> = {
  Minimize2, Maximize2, Crop, ArrowRightLeft, ImageIcon, Paintbrush, Sparkles, Eraser, Droplets, Laugh, RotateCw, Code, ScanFace
};

function getIconComponent(iconName: string) {
  return iconMap[iconName] || null;
}

const categories = [...new Set(tools.map(t => t.category))];
---

<Base title="Free Online Image Tools" description="16 powerful image tools. All run in your browser. Your images never leave your device.">
  <section class="relative overflow-hidden bg-gradient-to-b from-[var(--color-surface)] to-[var(--color-surface-2)] py-20 sm:py-28">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-[var(--color-text-main)] mb-6">
          Free Online Image Tools
          <span class="block text-gradient mt-2">No Upload, No Wait</span>
        </h1>
        <p class="text-lg sm:text-xl text-[var(--color-text-muted)] mb-8 max-w-2xl mx-auto">
          16 powerful tools. All run in your browser. Your images never leave your device.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#tools" class="btn-primary">
            Explore Tools
          </a>
          <a href="/tools" class="btn-secondary">
            All Tools
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-[var(--color-surface-2)]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="flex flex-col items-center text-center">
          <div class="w-12 h-12 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
          <span class="font-semibold text-[var(--color-text-main)]">100% Private</span>
          <span class="text-sm text-[var(--color-text-muted)]">All processing in browser</span>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="w-12 h-12 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <span class="font-semibold text-[var(--color-text-main)]">No Account</span>
          <span class="text-sm text-[var(--color-text-muted)]">Use instantly</span>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="w-12 h-12 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636a9 9 0 010 12.728m0 0l-2.829-2.829m2.829 2.829L21 21M15.536 8.464a5 5 0 010 7.072m0 0l-2.829-2.829m-4.243 2.829a4 4 0 01-1.414-2.83m-1.414 5.658a9 9 0 01-2.167-9.238m7.824 2.167a1 1 0 111.414 1.414m-1.414-1.414L3 3m8.293 8.293l1.414 1.414"/></svg>
          </div>
          <span class="font-semibold text-[var(--color-text-main)]">Works Offline</span>
          <span class="text-sm text-[var(--color-text-muted)]">No internet needed</span>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="w-12 h-12 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <span class="font-semibold text-[var(--color-text-main)]">Free Forever</span>
          <span class="text-sm text-[var(--color-text-muted)]">No hidden costs</span>
        </div>
      </div>
    </div>
  </section>

  <section id="tools" class="py-16 sm:py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-[var(--color-text-main)] mb-8 text-center">All Image Tools</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {tools.map((tool) => {
          const IconComponent = getIconComponent(tool.icon.name);
          return (
            <a href={tool.href} class="tool-card group">
              <div class="flex items-center gap-3 mb-3">
                {IconComponent && <IconComponent class="w-8 h-8 text-[var(--color-primary)]" />}
                <h3 class="text-lg font-bold text-[var(--color-text-main)] group-hover:text-[var(--color-primary)] transition-colors">
                  {tool.name}
                </h3>
                {tool.isNew && <span class="badge-new">NEW</span>}
              </div>
              <p class="text-sm text-[var(--color-text-muted)]">{tool.description}</p>
              <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-[var(--color-primary)]">
                Try Now <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="py-16 bg-[var(--color-surface-2)]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-[var(--color-text-main)] mb-6">How It Works</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="flex flex-col items-center">
            <div class="w-16 h-16 rounded-full bg-[var(--color-primary)] text-white flex items-center justify-center text-2xl font-bold mb-4">1</div>
            <h3 class="font-bold text-[var(--color-text-main)] mb-2">Upload</h3>
            <p class="text-[var(--color-text-muted)] text-sm">Drop your images or click to browse</p>
          </div>
          <div class="flex flex-col items-center">
            <div class="w-16 h-16 rounded-full bg-[var(--color-primary)] text-white flex items-center justify-center text-2xl font-bold mb-4">2</div>
            <h3 class="font-bold text-[var(--color-text-main)] mb-2">Process</h3>
            <p class="text-[var(--color-text-muted)] text-sm">Adjust settings and let AI do the work</p>
          </div>
          <div class="flex flex-col items-center">
            <div class="w-16 h-16 rounded-full bg-[var(--color-primary)] text-white flex items-center justify-center text-2xl font-bold mb-4">3</div>
            <h3 class="font-bold text-[var(--color-text-main)] mb-2">Download</h3>
            <p class="text-[var(--color-text-muted)] text-sm">Get your processed images instantly</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto bg-[var(--color-surface-2)] rounded-2xl p-8 text-center">
        <svg class="w-16 h-16 mx-auto mb-4 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        <h2 class="text-2xl font-bold text-[var(--color-text-main)] mb-4">Your Images Never Leave Your Browser</h2>
        <p class="text-[var(--color-text-muted)] mb-4">
          All image processing happens entirely on your device. We don't upload your photos to any server.
          This means your images are never transmitted over the internet, making our tools completely private and secure.
          Even if you lose internet connection mid-process, your work will be saved locally.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-[var(--color-surface-2)]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-[var(--color-text-main)] mb-8 text-center">Frequently Asked Questions</h2>
      <div class="max-w-2xl mx-auto space-y-4">
        <details class="group bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg overflow-hidden">
          <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
            <span class="font-semibold text-[var(--color-text-main)] pr-4">Is this really free?</span>
            <svg class="w-5 h-5 text-[var(--color-text-muted)] transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-4 pb-4 text-[var(--color-text-muted)]">Yes, absolutely free. No hidden fees, no premium tier, no watermarks on output.</div>
        </details>
        <details class="group bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg overflow-hidden">
          <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
            <span class="font-semibold text-[var(--color-text-main)] pr-4">Are my images secure?</span>
            <svg class="w-5 h-5 text-[var(--color-text-muted)] transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-4 pb-4 text-[var(--color-text-muted)]">100% secure. All processing happens in your browser. We never see or store your images.</div>
        </details>
        <details class="group bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg overflow-hidden">
          <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
            <span class="font-semibold text-[var(--color-text-main)] pr-4">What formats do you support?</span>
            <svg class="w-5 h-5 text-[var(--color-text-muted)] transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-4 pb-4 text-[var(--color-text-muted)]">JPG, PNG, GIF, SVG, WEBP, HEIC, TIFF, and more. Each tool supports specific formats.</div>
        </details>
        <details class="group bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg overflow-hidden">
          <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
            <span class="font-semibold text-[var(--color-text-main)] pr-4">Can I process multiple images at once?</span>
            <svg class="w-5 h-5 text-[var(--color-text-muted)] transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-4 pb-4 text-[var(--color-text-muted)]">Yes! Most tools support batch processing. Upload up to 20 images at once.</div>
        </details>
        <details class="group bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg overflow-hidden">
          <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
            <span class="font-semibold text-[var(--color-text-main)] pr-4">Do I need to create an account?</span>
            <svg class="w-5 h-5 text-[var(--color-text-muted)] transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-4 pb-4 text-[var(--color-text-muted)]">No account needed. Use any tool instantly without signing up.</div>
        </details>
        <details class="group bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg overflow-hidden">
          <summary class="flex items-center justify-between p-4 cursor-pointer list-none">
            <span class="font-semibold text-[var(--color-text-main)] pr-4">Which devices work?</span>
            <svg class="w-5 h-5 text-[var(--color-text-muted)] transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-4 pb-4 text-[var(--color-text-muted)]">Works on desktop, tablet, and mobile. Requires a modern browser with JavaScript enabled.</div>
        </details>
      </div>
    </div>
  </section>
</Base>

<style>
  .text-gradient {
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>